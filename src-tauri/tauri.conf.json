{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AR Anatomy Explorer",
  "version": "0.1.0",
  "identifier": "com.paul.ar-project",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AR Anatomy Explorer",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": {
        "default-src": ["'self'", "data:", "blob:"],
        "script-src": ["'self'"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": ["'self'", "data:", "blob:"],
        "connect-src": ["'self'", "http://localhost:5173"],
        "font-src": ["'self'"],
        "worker-src": ["'self'", "blob:"],
        "child-src": ["blob:"],
        "media-src": ["'self'", "blob:"]
      }
    }
  },
  "tauri": {
    "allowlist": {
      "window": {
        "all": true
      },
      "shell": {
        "open": true,
        "execute": false
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
